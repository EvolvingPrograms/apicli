{
  "name": "apicli",
  "version": "0.1.0",
  "description": "Schema-driven API client + auto-generated CLI. One zod schema → typed client + generic `api <endpoint>` subcommand + ergonomic `defineCommand` wrappers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test src",
    "test:qa": "bun test qa",
    "test:coverage": "bun test --coverage src",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --fix"
  },
  "keywords": [
    "api",
    "cli",
    "zod",
    "commander",
    "schema",
    "typesafe",
    "rest"
  ],
  "author": {
    "name": "Lewis (ss151)",
    "email": "lewis@spellcraft.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvolvingPrograms/apicli.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@types/bun": "latest",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
